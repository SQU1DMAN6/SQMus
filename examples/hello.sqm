NAME Simple Riff

tp 92
time 4/4

el {
    tn std
    drv g 0.48 t 0.56 l 0.88
    amp g 0.72 t 0.62 l 0.90
    pick p 0.64 a 0.58
    str d 0.24
    body r 0.34
    cho d 0.12 r 0.9 m 0.18
    rev r 0.26 m 0.15
}

Section Main

b 1 {
    q: s2,0
    q: s2,2
    q: s2,3 hm to 5
    q: n
}

b 2 {
    e: s1,3
    e: s1,5 sl to 7
    q: s2,5 bd
    q: s3,2
}

b End {
    h: s1,7 vb
    h: s1,0 hm
}
